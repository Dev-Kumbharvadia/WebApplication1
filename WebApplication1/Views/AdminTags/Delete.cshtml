@model WebApplication1.Models.Domain.Tag

<div class="bg-secondary bg-opacity-10 py-2">
    <div class="container">
        <h1>Delete Tag (Admin User)</h1>
    </div>
</div>

<div class="container py-5">
    <h3>Are you sure you want to delete this tag?</h3>
    <div>
        <strong>Id:</strong> @Model.Id
    </div>
    <div>
        <strong>Name:</strong> @Model.Name
    </div>
    <div>
        <strong>Display Name:</strong> @Model.DisplayName
    </div>

    <form asp-action="DeleteConfirmed" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="mb-3">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="List" class="btn btn-secondary">Cancel</a>
        </div>
    </form>

</div>
